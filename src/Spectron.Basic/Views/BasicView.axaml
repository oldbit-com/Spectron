<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:OldBit.Spectron.Basic.ViewModels"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="OldBit.Spectron.Basic.Views.BasicView"
        x:DataType="viewModels:BasicViewModel"
        Loaded="Control_OnLoaded"
        WindowStartupLocation="CenterOwner"
        Width="900"
        Height="700"
        Title="Basic View">

    <Grid Margin="10">
        <avaloniaEdit:TextEditor
            Name="BasicViewer"
            IsReadOnly="True"
            Text="Hello AvaloniaEdit!"
            FontFamily="{StaticResource SpectrumFont}"/>
    </Grid>

</Window>
